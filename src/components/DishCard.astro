---
import type { CollectionEntry } from 'astro:content';

interface Props {
  dish: CollectionEntry<'dishes'>;
}

const { dish } = Astro.props;
const { name, price, category, tags, image } = dish.data;
---

<a href={`/dish/${dish.slug}`} class="dish-card">
  <div class="image-wrapper">
    {image ? (
      <img src={image} alt={name} loading="lazy" />
    ) : (
      <div class="placeholder">
        <span>🍽️</span>
      </div>
    )}
    <span class="category">{category}</span>
  </div>
  <div class="content">
    <h3 class="name">{name}</h3>
    <div class="tags">
      {tags?.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    <p class="price">¥{price}</p>
  </div>
</a>

<style>
  .dish-card {
    display: block;
    background: var(--color-card);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .dish-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .image-wrapper {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }

  .category {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(0,0,0,0.6);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .content {
    padding: 16px;
  }

  .name {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .tag {
    background: var(--color-bg);
    color: var(--color-primary);
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
  }
</style>
