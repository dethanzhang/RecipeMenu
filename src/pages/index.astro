---
import Layout from '../layouts/Layout.astro';
import DishCard from '../components/DishCard.astro';
import { getCollection } from 'astro:content';

const dishes = await getCollection('dishes', ({ id }) => !id.includes('/_') && !id.startsWith('_'));

// 从文件路径提取 category（子文件夹名）
function getCategory(dish: typeof dishes[0]) {
  const parts = dish.id.split('/');
  return parts.length > 1 ? parts[0] : '其他';
}

// 自定义分类排序顺序（在这里修改分类显示顺序）
const categoryOrder = ['热菜','主食','素菜','凉菜','配菜零食'];

// 按分类分组
const categories = [...new Set(dishes.map(d => getCategory(d)))]
  // 按自定义顺序排序
  .sort((a, b) => {
    const indexA = categoryOrder.indexOf(a);
    const indexB = categoryOrder.indexOf(b);
    // 如果都在排序列表中，按列表顺序
    if (indexA !== -1 && indexB !== -1) return indexA - indexB;
    // 如果只有一个在列表中，在列表中的排前面
    if (indexA !== -1) return -1;
    if (indexB !== -1) return 1;
    // 都不在列表中，按字母排序
    return a.localeCompare(b, 'zh-CN');
  });

const dishesByCategory = categories.map(cat => ({
  name: cat,
  dishes: dishes.filter(d => getCategory(d) === cat)
}));

// 获取所有标签
const allTags = [...new Set(dishes.flatMap(d => d.data.tags || []))];
---

<Layout title="菜单">
  <div class="container">
    <!-- 标签筛选 -->
    {allTags.length > 0 && (
      <section class="filter-section">
        <div class="tags-filter" id="tags-filter">
          <button class="tag-btn active" data-filter="all">全部</button>
          {allTags.map(tag => (
            <button class="tag-btn" data-filter={tag}>{tag}</button>
          ))}
        </div>
      </section>
    )}

    <!-- 菜品列表 -->
    <div id="menu-content">
      {dishesByCategory.map(({ name, dishes }) => (
        <section class="category-section" data-category={name}>
          <h2 class="category-title">{name}</h2>
          <div class="dishes-grid">
            {dishes.map(dish => (
              <DishCard dish={dish} />
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- 简单计数 -->
    <div class="menu-footer">
      <p>共 {dishes.length} 道美味</p>
    </div>
  </div>
</Layout>

<script>
  // 简单的标签筛选功能
  const tagButtons = document.querySelectorAll('.tag-btn');
  const dishCards = document.querySelectorAll('.dish-card');

  tagButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // 更新按钮状态
      tagButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // 筛选卡片
      dishCards.forEach(card => {
        if (filter === 'all') {
          card.style.display = 'block';
        } else {
          const tags = card.querySelectorAll('.tag');
          const hasTag = Array.from(tags).some(t => t.textContent === filter);
          card.style.display = hasTag ? 'block' : 'none';
        }
      });

      // 显示/隐藏分类标题
      document.querySelectorAll('.category-section').forEach(section => {
        const visibleCards = section.querySelectorAll('.dish-card[style="display: block;"], .dish-card:not([style*="none"])');
        section.style.display = visibleCards.length > 0 ? 'block' : 'none';
      });
    });
  });
</script>

<style>
  .filter-section {
    margin: 24px 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tags-filter {
    display: flex;
    gap: 8px;
    padding-bottom: 4px;
    white-space: nowrap;
  }

  .tag-btn {
    padding: 10px 20px;
    border: 2px solid transparent;
    background: var(--color-card);
    border-radius: 24px;
    font-size: 0.875rem;
    cursor: pointer;
    transition: var(--transition);
    color: var(--color-text);
    box-shadow: var(--shadow);
    font-weight: 500;
    white-space: nowrap;
  }

  .tag-btn:hover {
    border-color: var(--color-primary-light);
    color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .tag-btn.active {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: white;
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(230, 81, 0, 0.3);
  }

  .category-section {
    margin-bottom: 32px;
  }

  .category-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding: 12px 16px;
    background: linear-gradient(90deg, var(--color-card) 0%, transparent 100%);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    box-shadow: var(--shadow);
  }

  .dishes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
    align-items: stretch;
  }

  .dishes-grid > :global(*) {
    height: 100%;
  }

  @media (max-width: 640px) {
    .dishes-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  @media (max-width: 400px) {
    .dishes-grid {
      grid-template-columns: 1fr;
    }
  }

  .menu-footer {
    text-align: center;
    padding: 40px 0;
    color: var(--color-text-light);
    margin-top: 24px;
    font-size: 0.9375rem;
  }

  .menu-footer p {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: linear-gradient(135deg, #fff8e1 0%, #ffe0b2 100%);
    border-radius: 24px;
    font-weight: 500;
  }
</style>
