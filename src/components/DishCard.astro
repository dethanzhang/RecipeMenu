---
import type { CollectionEntry } from 'astro:content';

interface Props {
  dish: CollectionEntry<'dishes'>;
}

const { dish } = Astro.props;
const { name, price, category, tags, image } = dish.data;
---

<a href={`/dish/${dish.id}`} class="dish-card">
  <div class="image-wrapper">
    {image ? (
      <>
        <img src={image} alt={name} loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
        <div class="placeholder" style="display: none;">
          <span>暂无图片</span>
        </div>
      </>
    ) : (
      <div class="placeholder">
        <span>暂无图片</span>
      </div>
    )}
    <span class="category">{category}</span>
  </div>
  <div class="content">
    <h3 class="name">{name}</h3>
    <div class="tags">
      {tags?.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    <p class="price">{price}</p>
  </div>
</a>

<style>
  .dish-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
    height: 100%;
    position: relative;
  }

  .dish-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .dish-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: var(--shadow-hover);
  }

  .dish-card:hover::before {
    opacity: 1;
  }

  .image-wrapper {
    position: relative;
    height: 150px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
    overflow: hidden;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dish-card:hover .image-wrapper img {
    transform: scale(1.1);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f0e8 0%, #e8e0d5 100%);
    color: #a09080;
    font-size: 0.875rem;
    flex-direction: column;
    gap: 8px;
  }

  .placeholder::before {
    content: '🍽️';
    font-size: 2.5rem;
    opacity: 0.5;
  }

  .category {
    position: absolute;
    top: 10px;
    left: 10px;
    background: linear-gradient(135deg, rgba(230, 81, 0, 0.9) 0%, rgba(255, 152, 0, 0.9) 100%);
    color: white;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    backdrop-filter: blur(4px);
  }

  .content {
    padding: 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 8px;
  }

  .name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
    color: var(--color-primary-dark);
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(230, 81, 0, 0.1);
  }

  .price {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-top: auto;
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .price::before {
    content: '¥';
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Card entrance animation */
  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .dish-card {
    animation: cardEnter 0.5s ease-out backwards;
  }
</style>
