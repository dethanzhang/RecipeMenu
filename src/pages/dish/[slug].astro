---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const dishes = await getCollection('dishes', ({ id }) => !id.startsWith('_'));
  return dishes.map(dish => ({
    params: { slug: dish.id },
    props: { dish },
  }));
}

interface Props {
  dish: CollectionEntry<'dishes'>;
}

const { dish } = Astro.props;
const { Content } = await render(dish);
const { name, price, category, tags, time, difficulty, image, ingredients } = dish.data;
---

<Layout title={`${name} - 食谱详情`}>
  <div class="container">
    <!-- 返回按钮 -->
    <a href="/" class="back-link">← 返回菜单</a>

    <article class="dish-detail">
      <!-- 头部信息 -->
      <header class="dish-header">
        <div class="image-section">
          {image ? (
            <img src={image} alt={name} class="dish-image" />
          ) : (
            <div class="placeholder">
              <span>🍽️</span>
            </div>
          )}
        </div>

        <div class="info-section">
          <div class="category-badge">{category}</div>
          <h1>{name}</h1>

          <div class="meta-info">
            {time && (
              <span class="meta-item">
                <span class="icon">⏱️</span>
                {time}
              </span>
            )}
            {difficulty && (
              <span class="meta-item">
                <span class="icon">📊</span>
                {difficulty}
              </span>
            )}
          </div>

          <div class="tags">
            {tags?.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>

          <p class="price">¥{price}</p>
        </div>
      </header>

      <!-- 食材清单 -->
      {ingredients && ingredients.length > 0 && (
        <section class="ingredients-section">
          <h2>🥬 食材清单</h2>
          <ul class="ingredients-list">
            {ingredients.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- 烹饪步骤 -->
      <section class="recipe-section">
        <h2>👨‍🍳 烹饪指南</h2>
        <div class="prose">
          <Content />
        </div>
      </section>
    </article>
  </div>
</Layout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 20px;
    color: var(--color-text-light);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .dish-detail {
    background: var(--color-card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .dish-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  @media (max-width: 768px) {
    .dish-header {
      grid-template-columns: 1fr;
    }
  }

  .image-section {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  }

  .dish-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
  }

  .info-section {
    padding: 32px;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 640px) {
    .info-section {
      padding: 20px;
    }
  }

  .category-badge {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 12px;
    width: fit-content;
  }

  .info-section h1 {
    font-size: 1.75rem;
    margin-bottom: 16px;
  }

  .meta-info {
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-text-light);
    font-size: 0.9375rem;
  }

  .icon {
    font-size: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tag {
    background: var(--color-bg);
    color: var(--color-primary);
    padding: 4px 12px;
    border-radius: 16px;
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: auto 0 0;
  }

  .ingredients-section,
  .recipe-section {
    padding: 32px;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .ingredients-section,
    .recipe-section {
      padding: 20px;
    }
  }

  .ingredients-section h2,
  .recipe-section h2 {
    font-size: 1.25rem;
    margin-bottom: 20px;
    color: var(--color-primary);
  }

  .ingredients-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 8px 24px;
    list-style: none;
    padding: 0;
  }

  .ingredients-list li {
    padding: 8px 0;
    border-bottom: 1px dashed var(--color-border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ingredients-list li::before {
    content: "•";
    color: var(--color-primary);
    font-weight: bold;
  }

  .prose {
    line-height: 1.8;
  }

  .prose ol {
    counter-reset: step-counter;
    list-style: none;
    padding: 0;
  }

  .prose ol li {
    counter-increment: step-counter;
    position: relative;
    padding-left: 40px;
    margin-bottom: 16px;
  }

  .prose ol li::before {
    content: counter(step-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .prose strong {
    color: var(--color-primary);
    font-weight: 600;
  }

  .prose h2 {
    margin-top: 32px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
  }
</style>
