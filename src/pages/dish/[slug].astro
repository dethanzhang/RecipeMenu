---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const dishes = await getCollection('dishes', ({ id }) => !id.startsWith('_'));
  return dishes.map(dish => ({
    params: { slug: dish.id },
    props: { dish },
  }));
}

interface Props {
  dish: CollectionEntry<'dishes'>;
}

const { dish } = Astro.props;
const { Content } = await render(dish);
const name = dish.data.name ?? dish.id;
const { price, category, tags, time, difficulty, image, ingredients } = dish.data;
---

<Layout title={`${name} - 食谱详情`}>
  <div class="container">
    <!-- 返回按钮 -->
    <a href="/" class="back-link">← 返回菜单</a>

    <article class="dish-detail">
      <!-- 头部信息 -->
      <header class="dish-header">
        <div class="image-section">
          {image ? (
            <>
              <img src={image} alt={name} class="dish-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
              <div class="placeholder" style="display: none;">
                <span>暂无图片</span>
              </div>
            </>
          ) : (
            <div class="placeholder">
              <span>暂无图片</span>
            </div>
          )}
        </div>

        <div class="info-section">
          <div class="category-badge">{category}</div>
          <h1>{name}</h1>

          <div class="meta-info">
            {time && (
              <span class="meta-item">
                <span class="icon">⏱️</span>
                {time}
              </span>
            )}
            {difficulty && (
              <span class="meta-item">
                <span class="icon">📊</span>
                {difficulty}
              </span>
            )}
          </div>

          <div class="tags">
            {tags?.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>

          <p class="price">¥{price}</p>
        </div>
      </header>

      <!-- 食材清单 -->
      {ingredients && ingredients.length > 0 && (
        <section class="ingredients-section">
          <h2>🥬 食材清单</h2>
          <ul class="ingredients-list">
            {ingredients.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- 烹饪步骤 -->
      <section class="recipe-section">
        <h2>👨‍🍳 烹饪指南</h2>
        <div class="prose">
          <Content />
        </div>
      </section>
    </article>
  </div>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 24px;
    color: var(--color-text-light);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 10px 16px;
    background: var(--color-card);
    border-radius: 24px;
    box-shadow: var(--shadow);
    transition: var(--transition);
  }

  .back-link:hover {
    color: var(--color-primary);
    transform: translateX(-4px);
    box-shadow: var(--shadow-md);
  }

  .dish-detail {
    background: var(--color-card);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .dish-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  @media (max-width: 768px) {
    .dish-header {
      grid-template-columns: 1fr;
    }
  }

  .image-section {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
    overflow: hidden;
    position: relative;
  }

  .image-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(to top, rgba(0,0,0,0.1) 0%, transparent 100%);
    pointer-events: none;
  }

  .dish-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .image-section:hover .dish-image {
    transform: scale(1.05);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f0e8 0%, #e8e0d5 100%);
    color: #a09080;
    font-size: 1.125rem;
    flex-direction: column;
    gap: 12px;
  }

  .placeholder::before {
    content: '🍽️';
    font-size: 4rem;
    opacity: 0.5;
  }

  .info-section {
    padding: 32px;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 640px) {
    .info-section {
      padding: 20px;
    }
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 16px;
    width: fit-content;
    box-shadow: 0 2px 8px rgba(230, 81, 0, 0.3);
  }

  .info-section h1 {
    font-size: 2rem;
    margin-bottom: 16px;
    color: var(--color-text);
    font-weight: 800;
    line-height: 1.3;
  }

  .meta-info {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text-light);
    font-size: 0.9375rem;
    padding: 8px 14px;
    background: var(--color-bg);
    border-radius: 20px;
    font-weight: 500;
  }

  .icon {
    font-size: 1.125rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tag {
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
    color: var(--color-primary-dark);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid rgba(255, 152, 0, 0.15);
    transition: var(--transition);
  }

  .tag:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .price {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: auto 0 0;
    display: flex;
    align-items: baseline;
    gap: 4px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ingredients-section,
  .recipe-section {
    padding: 32px;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .ingredients-section,
    .recipe-section {
      padding: 20px;
    }
  }

  .ingredients-section h2,
  .recipe-section h2 {
    font-size: 1.375rem;
    margin-bottom: 24px;
    color: var(--color-primary-dark);
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ingredients-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px 24px;
    list-style: none;
    padding: 0;
  }

  .ingredients-list li {
    padding: 12px 16px;
    background: linear-gradient(135deg, #fff8e1 0%, #fff3e0 100%);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 500;
    transition: var(--transition);
    border: 1px solid rgba(255, 152, 0, 0.1);
  }

  .ingredients-list li:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow);
  }

  .ingredients-list li::before {
    content: "✓";
    color: var(--color-primary);
    font-weight: bold;
    width: 22px;
    height: 22px;
    background: var(--color-card);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    box-shadow: var(--shadow);
  }

  .prose {
    line-height: 1.8;
  }

  .prose ol {
    counter-reset: step-counter;
    list-style: none;
    padding: 0;
  }

  .prose ol li {
    counter-increment: step-counter;
    position: relative;
    padding-left: 48px;
    margin-bottom: 20px;
    padding: 16px 16px 16px 48px;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    transition: var(--transition);
  }

  .prose ol li:hover {
    background: linear-gradient(135deg, #fff8e1 0%, #fff3e0 100%);
    transform: translateX(4px);
  }

  .prose ol li::before {
    content: counter(step-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(230, 81, 0, 0.3);
  }

  .prose strong {
    color: var(--color-primary);
    font-weight: 600;
  }

  .prose h2 {
    margin-top: 32px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
  }
</style>
